# Python local env (optional tooling)
.venv/

# macOS
.DS_Store

# Xcode
build/
DerivedData/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/*.xcodeproj/project.xcworkspace/xcuserdata/

# Swift Package Manager
.build/
.swiftpm/
# Ignore SPM lockfile at the repo root (we're a library; downstream xcodeprojs
# pin versions). Allow the Xcode workspace's lockfile through — Xcode Cloud
# requires a committed Package.resolved to resolve SPM deps in CI.
/Package.resolved

# Secrets and local config
.env
.env.*
!.env.example
Secrets.plist
*.p8
*.pem
*.key

# Local artifacts
.voiceflow/
logs/
recordings/
tmp/
*.wav
*.m4a
*.caf

# Allow checked-in test fixtures
!Tests/**/Fixtures/*.wav

# Test and cache artifacts
.pytest_cache/
__pycache__/
*.pyc
coverage/
